# Is file ko copy karke ".env" banao aur values bharo (local testing ke liye).
# GitHub par ye values "Secrets" me daalni hain, .env me nahi.

# OpenAI key (paid) — ya Groq key (free) ke saath base_url
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# FREE option (Groq): upar Groq ka key daalo aur ye 2 uncomment karo
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Channel ka @username ya -100... numeric id
CHANNEL_ID=-1001234567890

# Group ki -100... numeric id (optional — na ho to hata do)
GROUP_ID=
